generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(cuid())
  clerkId        String         @unique
  email          String
  name           String?
  role           UserRole       @default(CLIENT)
  plan           Plan           @default(STARTER)
  forms          Form[]         @relation("AgencyForms")
  clientForms    Form[]         @relation("ClientForms")
  agencyClients  AgencyClient[] @relation("AgencyToClient")
  clientAgencies AgencyClient[] @relation("ClientToAgency")
  invitations    Invitation[]
  createdAt      DateTime       @default(now())
}

model AgencyClient {
  id        String   @id @default(cuid())
  agencyId  String
  agency    User     @relation("AgencyToClient", fields: [agencyId], references: [id], onDelete: Cascade)
  clientId  String
  client    User     @relation("ClientToAgency", fields: [clientId], references: [id], onDelete: Cascade)
  logoUrl   String?
  createdAt DateTime @default(now())

  @@unique([agencyId, clientId])
  @@index([agencyId])
  @@index([clientId])
}

model Invitation {
  id        String           @id @default(cuid())
  agencyId  String
  agency    User             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  @@index([agencyId])
  @@index([token])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum UserRole {
  SUPER_ADMIN
  AGENCY
  CLIENT
}

enum Plan {
  STARTER
  PRO
  AGENCY
}

model Form {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation("AgencyForms", fields: [userId], references: [id])
  clientId         String?
  client           User?         @relation("ClientForms", fields: [clientId], references: [id])
  title            String
  description      String?
  status           FormStatus    @default(DRAFT)
  settings         Json          @default("{}")
  steps            Step[]
  responses        Response[]
  licenseStatus    LicenseStatus @default(PENDING)
  licenseExpiresAt DateTime?
  dataDeleteAt     DateTime?
  stripePaymentId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([clientId])
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LicenseStatus {
  PENDING
  ACTIVE
  EXPIRED
  DELETED
}

model Step {
  id     String  @id @default(cuid())
  formId String
  form   Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  order  Int
  title  String
  fields Field[]
}

model Field {
  id          String    @id @default(cuid())
  stepId      String
  step        Step      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  order       Int
  type        FieldType
  label       String
  placeholder String?
  helpText    String?
  required    Boolean   @default(false)
  options     Json?
  efoSettings Json?
  logic       Json?
}

enum FieldType {
  TEXT
  EMAIL
  TEL
  TEXTAREA
  SELECT
  RADIO
  CHECKBOX
  DATE
  ZIP
  NAME
  AGREE
  FILE
  HEADING
  PARAGRAPH
  DIVIDER
}

model Response {
  id             String         @id @default(cuid())
  formId         String
  form           Form           @relation(fields: [formId], references: [id])
  data           Json
  metadata       Json?
  isRead         Boolean        @default(false)
  responseStatus ResponseStatus @default(PENDING)
  memo           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
}

enum ResponseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

model FormEvent {
  id        String         @id @default(cuid())
  formId    String
  type      FormEventType
  stepIndex Int?
  sessionId String
  createdAt DateTime       @default(now())

  @@index([formId, createdAt])
}

enum FormEventType {
  VIEW
  STEP_COMPLETE
  SUBMIT
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String
  detail     Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
}
